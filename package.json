{
  "name": "codepen-pro-server",
  "version": "3.0.0",
  "description": "CodePen Pro Server на Cloudflare Workers с D1 и KV",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute codepen-pro-db --file=./schema.sql",
    "db:init:local": "wrangler d1 execute codepen-pro-db --local --file=./schema.sql"
  },
  "keywords": [
    "codepen",
    "workers",
    "d1",
    "kv"
  ],
  "author": "CodePen Pro Team",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "hono": "^4.0.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.110.0"
  }
}
